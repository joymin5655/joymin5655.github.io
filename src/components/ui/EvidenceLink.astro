---
// Evidence micro-pattern — every quantitative claim links to its source (R5).
interface Props {
  href: string;
  label: string;
}
const { href, label } = Astro.props;
const external = href.startsWith('http') || href.startsWith('mailto');
---

<a class="ev" href={href} target={external ? '_blank' : undefined} rel={external ? 'noopener' : undefined}>
  ↳ EVIDENCE · {label}
</a>
