---
import type { Locale } from '../data/site';
import GooeyText from './GooeyText.astro';
interface Props { data: Locale; }
const { data } = Astro.props;
const { hero, metrics, about, principles, projects, skills, timeline, credentials, contact, nav } = data;
---

<nav class="nav">
  <div class="wrap">
    <a class="brand" href={data.lang === 'ko' ? '/' : '/en/'}>Yongmin <b>Cho</b></a>
    <div class="links">
      <a class="navlink" href="#about">{nav.about}</a>
      <a class="navlink" href="#principles">{nav.principles}</a>
      <a class="navlink" href="#projects">{nav.projects}</a>
      <a class="navlink" href="#skills">{nav.skills}</a>
      <a class="navlink" href="#timeline">{nav.timeline}</a>
      <a class="navlink" href="#contact">{nav.contact}</a>
      <a class="lang" href={data.altHref} aria-label="language">{data.altLabel}</a>
    </div>
    <details class="mnav">
      <summary class="mnav-btn" aria-label={data.lang === 'ko' ? '메뉴' : 'Menu'}>
        <span class="mnav-icon" aria-hidden="true"></span>
      </summary>
      <div class="mnav-panel">
        <a href="#about">{nav.about}</a>
        <a href="#principles">{nav.principles}</a>
        <a href="#projects">{nav.projects}</a>
        <a href="#skills">{nav.skills}</a>
        <a href="#timeline">{nav.timeline}</a>
        <a href="#contact">{nav.contact}</a>
        <a class="mnav-lang" href={data.altHref}>{data.altLabel}</a>
      </div>
    </details>
  </div>
</nav>

<header class="hero">
  <div class="wrap">
    <p class="role">{hero.role}</p>
    <h1>{hero.name}<br /><span class="grad">{hero.tagline}</span></h1>
    <GooeyText texts={hero.gooey} class="hero-gooey" id="hero-gooey" />
    <p class="sub">{hero.sub}</p>
    <div class="ctas">
      {hero.ctas.map((c) => (
        <a class={`btn ${c.primary ? 'primary' : ''}`} href={c.url} target={c.url.startsWith('#') ? undefined : '_blank'} rel={c.url.startsWith('#') ? undefined : 'noopener'}>{c.label}</a>
      ))}
    </div>
  </div>
</header>

<main>
  <section class="metrics-strip">
    <div class="wrap">
      {metrics.map((m, i) => (
        <div class="metric reveal" style={`--i:${i}`}>
          <span class="metric-value">{m.value}</span>
          <span class="metric-label">{m.label}</span>
        </div>
      ))}
    </div>
  </section>

  <section id="about" class="about">
    <div class="wrap">
      <p class="eyebrow">{nav.about}</p>
      <p class="lead">{about.lead}</p>
      <div class="pillars">
        {about.pillars.map((p, i) => (
          <div class="pillar reveal" style={`--i:${i}`}><h3>{p.title}</h3><p>{p.body}</p></div>
        ))}
      </div>
      <p class="motto">{about.motto}</p>
    </div>
  </section>

  <section id="principles" class="principles">
    <div class="wrap">
      <p class="eyebrow">{nav.principles}</p>
      <h2 class="section-title">{principles.heading}</h2>
      <div class="rules">
        {principles.items.map((p, i) => (
          <div class="rule reveal" style={`--i:${i}`}>
            <h3 class="rule-key">{p.title}</h3>
            <p class="rule-desc">{p.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="projects" class="projects">
    <div class="wrap">
      <p class="eyebrow">{nav.projects}</p>
      <h2 class="section-title">{projects.heading}</h2>
      <div class="projects-grid">
        {projects.items.map((proj, i) => (
          <article class={`card reveal ${proj.flagship ? 'flagship' : ''}`} style={`--i:${i}`}>
            <span class="badge">{proj.flagship ? '★ Flagship' : 'Project'}</span>
            <h3>{proj.name}</h3>
            <p class="tag">{proj.tag}</p>
            <p class="blurb">{proj.blurb}</p>
            <div class="chips">{proj.stack.map((s) => <span class="chip">{s}</span>)}</div>
            {(proj.links.length > 0 || proj.slug) && (
              <div class="links">
                {proj.slug && (
                  <a class="case-link" href={`${data.lang === 'ko' ? '' : '/en'}/projects/${proj.slug}`}>
                    {data.lang === 'ko' ? '케이스스터디' : 'Case study'} →
                  </a>
                )}
                {proj.links.map((l) => (
                  <a href={l.url} target="_blank" rel="noopener">{l.label} ↗</a>
                ))}
              </div>
            )}
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="skills" class="skills">
    <div class="wrap">
      <p class="eyebrow">{nav.skills}</p>
      <h2 class="section-title">{skills.heading}</h2>
      <div class="manifest">
        {skills.groups.map((g, i) => (
          <div class="manifest-row reveal" style={`--i:${i}`}>
            <h3 class="manifest-key">{g.group}</h3>
            <div class="items">{g.items.map((it) => <span class="chip">{it}</span>)}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="timeline" class="journey">
    <div class="wrap">
      <p class="eyebrow">{nav.timeline}</p>
      <h2 class="section-title">{timeline.heading}</h2>
      <div class="timeline">
        {timeline.items.map((t, i) => (
          <div
            class:list={[
              'tl-item',
              'reveal',
              t.period.startsWith('2024.08') && 'tl-item--branch',
              i === timeline.items.length - 1 && 'tl-item--current',
            ]}
            style={`--i:${i}`}
          >
            <p class="period">{t.period}</p>
            <h3>{t.title}</h3>
            <p>{t.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="credentials" class="credentials">
    <div class="wrap">
      <p class="eyebrow">{credentials.heading}</p>
      <h2 class="section-title">{credentials.heading}</h2>
      <div class="cred-grid">
        {credentials.groups.map((g, i) => (
          <div class="credgroup reveal" style={`--i:${i}`}>
            <h3>{g.label}</h3>
            <ul>{g.items.map((i) => <li>{i}</li>)}</ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="contact" class="contact">
    <div class="wrap">
      <p class="eyebrow">{nav.contact}</p>
      <h2 class="section-title">{contact.heading}</h2>
      <p class="lead">{contact.lead}</p>
      <div class="links">
        {contact.items.map((c) => (
          <a href={c.url} target={c.url.startsWith('mailto') ? undefined : '_blank'} rel="noopener">{c.label}</a>
        ))}
      </div>
    </div>
  </section>
</main>

<footer class="footer">
  <div class="wrap">
    <span>© 2026 Yongmin Cho (조용민)</span>
    <span class="mono">Built with Astro · Deployed on GitHub Pages</span>
  </div>
</footer>

<script>
  const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
  const els = document.querySelectorAll('.reveal');
  if (!reduce && 'IntersectionObserver' in window && els.length) {
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries)
          if (e.isIntersecting) {
            e.target.classList.add('is-visible');
            io.unobserve(e.target);
          }
      },
      { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
    );
    els.forEach((el) => io.observe(el));
    // safety net: never leave content hidden if the observer stalls
    setTimeout(() => els.forEach((el) => el.classList.add('is-visible')), 3000);
  }

  const mnav = document.querySelector('.mnav');
  if (mnav) {
    mnav.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => mnav.removeAttribute('open')));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') mnav.removeAttribute('open');
    });
  }
</script>
