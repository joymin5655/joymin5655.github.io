---
import Base from '../../../layouts/Base.astro';
import CaseStudy from '../../../components/CaseStudy.astro';
import { caseStudies } from '../../../data/site';

export function getStaticPaths() {
  return Object.keys(caseStudies.en.items).map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const loc = caseStudies.en;
const cs = loc.items[slug as string];
---
<Base
  data={{ lang: 'en', meta: cs.meta }}
  path={`/en/projects/${slug}`}
  altKo={`/projects/${slug}`}
  altEn={`/en/projects/${slug}`}
>
  <CaseStudy cs={cs} ui={loc.ui} backHref="/en/#projects" altHref={`/projects/${slug}`} altLabel="KO" />
</Base>
